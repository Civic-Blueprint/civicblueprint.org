# Public website URL used by Plausible analytics (production only).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=civicblueprint.org

# Preferred Plausible script URL (production only). When set, this takes precedence.
# Example: https://plausible.io/js/pa-xxxxxxxxxxxxxxxx.js
NEXT_PUBLIC_PLAUSIBLE_SRC=

# Microsoft Clarity project ID (production only). Leave blank to disable Clarity.
NEXT_PUBLIC_CLARITY_ID=

# Existing submission API environment variable.
NEXT_PUBLIC_SUBMISSION_API_URL=
